{"type":"message","id":"99003c4d","parentId":"36ce91cc","timestamp":"2026-04-12T12:49:39.077Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"ollama_call_8b8d32e9-e7d2-4778-8b27-153f6d575555","name":"exec","arguments":{"command":"cat << 'EOF' > /Users/louishyman/.openclaw/workspaces/maxwell-workspace/sweep_logic.py\nimport json\nimport datetime\nimport os\nimport sys\n\n# This script will be called by the agent. \n# It expects a JSON string of threads as input via stdin.\ndef classify(subject, snippet, date_str):\n    # Simple classification logic\n    # Date format: 2026-04-12T08:48:00Z\n    try:\n        msg_date = datetime.datetime.fromisoformat(date_str.replace('Z', '+00:00'))\n    except:\n        msg_date = datetime.datetime.now(datetime.timezone.utc)\n        \n    now = datetime.datetime.now(datetime.timezone.utc)\n    diff = (now - msg_date).total_seconds()\n    \n    subject_lower = subject.lower()\n    snippet_lower = snippet.lower()\n    \n    # Rules\n    if any(word in subject_lower or word in snippet_lower for word in ['urgent', 'immediate', 'action required', 'asap']):\n        return 'urgent'\n    if diff < 86400: # 24h\n        return 'today'\n    if diff < 604800: # 7 days\n        return 'this_week'\n    if any(word in subject_lower or word in snippet_lower for word in ['newsletter', 'update', 'announcement', 'digest']):\n        return 'fyi'\n    if any(word in subject_lower or word in snippet_lower for word in ['promo', 'sale', 'offer', 'unsubscribe']):\n        return 'spam_or_noise'\n    \n    return 'fyi'\n\ndef main():\n    try:\n        input_data = sys.stdin.read()\n        if not input_data:\n            print(json.dumps({\"error\": \"No input data\"}))\n            return\n            \n        threads = json.loads(input_data)\n        \n        counts = {\"urgent\": 0, \"today\": 0, \"this_week\": 0, \"fyi\": 0, \"spam_or_noise\": 0}\n        threads_scanned = 0\n        processed_threads = []\n\n        for thread in threads[:20]:\n            threads_scanned += 1\n            subject = thread.get('subject', '')\n            snippet = thread.get('snippet', '')\n            date_str = thread.get('date', '')\n            \n            cls = classify(subject, snippet, date_str)\n            counts[cls] += 1\n            \n            processed_threads.append({\n                \"id\": thread.get('id'),\n                \"subject\": subject,\n                \"classification\": cls,\n                \"date\": date_str\n            })\n\n        result = {\n            \"timestamp\": datetime.datetime.now(datetime.timezone.utc).isoformat(),\n            \"threads_scanned\": threads_scanned,\n            \"counts\": counts,\n            \"threads\": processed_threads\n        }\n        \n        print(json.dumps(result, indent=2))\n    except Exception as e:\n        print(json.dumps({\"error\": str(e)}))\n\nif __name__ == \"__main__\":\n    main()\nEOF\n"}}],"stopReason":"toolUse","api":"ollama","provider":"ollama","model":"gemma4:26b","usage":{"input":12041,"output":775,"cacheRead":0,"cacheWrite":0,"totalTokens":12816,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"timestamp":1775998179077}}
